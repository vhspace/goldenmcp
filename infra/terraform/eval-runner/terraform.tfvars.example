# Copy to terraform.tfvars and fill in non-secret values.
# Do NOT commit terraform.tfvars if it contains sensitive data.

region          = "nyc3"
droplet_size    = "s-4vcpu-8gb"
droplet_name    = "goldenmcp-eval-runner"
repo_url        = "https://github.com/vhspace/goldenmcp.git"
repo_branch     = "main"

# Existing SSH keys on your DigitalOcean account (apply script auto-discovers if unset).
# List with: doctl compute ssh-key list --format Name
# ssh_key_names = ["TAI", "chatresearch"]
