# GoldenMCP environment — copy to .env, or run: ./scripts/setup_eval_env.sh

# LLM for Inspect evals (any provider inspect-ai supports)
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
OPENAI_API_KEY=

# Eval chain defaults (see packages/inspect-web3/src/goldenmcp_inspect/eval_chains.py)
# Quote evals: Base mainnet. odos_swap: Fraxtal. ENS stays on Sepolia below.
EVAL_CHAIN_QUOTE=base
EVAL_CHAIN_QUOTE_ID=8453
EVAL_CHAIN_ODOS_SWAP=fraxtal
EVAL_CHAIN_ODOS_SWAP_ID=252

# Dedicated throwaway EOA for Odos stdio MCP — generate via ./scripts/setup_eval_env.sh
WALLET_PRIVATE_KEY=
EVM_EVAL_ADDRESS=

# MCP server URLs (live HTTP endpoints)
# LI.FI: https://docs.li.fi/mcp-server/overview — tools use hyphens (get-chains, get-quote)
LIFI_MCP_URL=https://mcp.li.quest/mcp
LIFI_API_KEY=

# Odos stdio MCP — no URL; Inspect spawns via npx (see mcp_connectors.py)
# Requires node/npx. setup_eval_env.sh sets WALLET_PRIVATE_KEY via cast wallet new.

# Uniswap: https://github.com/junct-bot/uniswap-mcp (hosted endpoint may be down)
# stdio fallback: `npx -y @kukapay/uniswap-trader-mcp`
UNISWAP_MCP_URL=https://uniswap.mcp.junct.dev/mcp

# 1inch: official hosted MCP (https://mcp.1inch.dev/mcp). Non-custodial.
# Public tools work keyless; swap/product_api need a dev-portal Bearer key.
ONEINCH_MCP_URL=https://mcp.1inch.dev/mcp
ONEINCH_API_KEY=

# KyberSwap: github.com/KyberNetwork/kyberswap-mcp (stdio, read-only — no npm package).
# Clone + `npm install && npm run build`, then point this at the built entrypoint:
KYBERSWAP_MCP_PATH=
KYBERSWAP_RPC_URL=

# Jupiter (Solana) stdio MCP — Inspect spawns via `npx -y jupiter-mcp-server`.
# Read-only Price/Portfolio API; no Solana keypair needed for quote/positions evals.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
JUPITER_API_KEY=

# RPC / infra
INFURA_KEY=

# Walrus testnet
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=1
# Set after first indexed upload (printed by post_eval_walrus.py as walrus_index_blob_id)
WALRUS_INDEX_BLOB_ID=

# Arc testnet
ARC_RPC_URL=
ARC_REGISTRY_ADDRESS=
ARC_USDC_ADDRESS=
MARKETPLACE_WALLET_PRIVATE_KEY=

# x402
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_PAYEE_ADDRESS=
MARKETPLACE_URL=http://localhost:8091

# ENS (Sepolia — separate from swap eval chains)
ENS_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ENS_PARENT_NAME=goldenmcp.eth

# Chainlink Confidential AI
CHAINLINK_CAI_API_KEY=
CHAINLINK_CAI_URL=

# Eval runner
EVAL_RUNNER_HOST=0.0.0.0
EVAL_RUNNER_PORT=8090
# Bearer token for CRE → eval-runner (generated on first sync if unset)
EVAL_RUNNER_API_KEY=
# Public HTTPS URL after DO deploy, e.g. https://<droplet_ip>
EVAL_RUNNER_PUBLIC_URL=

# DigitalOcean (Terraform only — never sync to droplet)
DO_API_KEY=

# Web demo
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_ARC_RPC_URL=
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_ENS_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
