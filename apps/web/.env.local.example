# Copy to .env.local (gitignored) or set in repo-root .env — next.config.js reads root .env too.
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_REGISTRY_ADDRESS=0xae264f008b37570cc6b22552f623b7e8c73d8123
ARC_REGISTRY_ADDRESS=0xae264f008b37570cc6b22552f623b7e8c73d8123
NEXT_PUBLIC_ENS_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
# Walrus index blob id (printed by scripts/post_eval_walrus.py as walrus_index_blob_id).
# Required only to resolve eval logs stored at walrus://evals/goldenmcp/...run.eval indexed paths.
WALRUS_INDEX_BLOB_ID=
# Optional: URL of a self-hosted `inspect view bundle` viewer index.html.
# Defaults to /inspect-viewer/index.html (commit the bundle output to apps/web/public/inspect-viewer).
NEXT_PUBLIC_INSPECT_VIEWER_URL=
MARKETPLACE_URL=http://localhost:8091
EVAL_RUNNER_PUBLIC_URL=
